<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>SpatialScope Agent Research Brief - {{ run_id }}</title>
  <style>
    :root {
      --ink: #172026;
      --muted: #66737f;
      --line: #d8e0e7;
      --surface: #f7f9fb;
      --teal: #0f766e;
      --plum: #6f4e8f;
      --amber: #b7791f;
      --rose: #b42318;
    }
    * { box-sizing: border-box; }
    body {
      background: #fff;
      color: var(--ink);
      font-family: "PingFang SC", "Noto Sans CJK SC", "Microsoft YaHei", Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.58;
      margin: 0;
    }
    main { margin: 0 auto; max-width: 1180px; padding: 36px 28px 54px; }
    header { border-bottom: 1px solid var(--line); margin-bottom: 24px; padding-bottom: 22px; }
    h1 { font-size: 34px; letter-spacing: 0; margin: 0 0 8px; }
    h2 { font-size: 20px; letter-spacing: 0; margin: 30px 0 12px; }
    h3 { font-size: 15px; margin: 0 0 8px; }
    p { margin: 8px 0; }
    a { color: var(--plum); }
    img { border: 1px solid #edf1f4; border-radius: 6px; max-width: 100%; }
    table { border-collapse: collapse; font-size: 13px; width: 100%; }
    th, td { border-bottom: 1px solid #e8edf2; padding: 8px 10px; text-align: left; vertical-align: top; }
    th { background: #fafbfc; color: var(--muted); font-weight: 700; }
    code, pre { background: #f3f6f8; border-radius: 4px; padding: 2px 4px; }
    pre { border: 1px solid var(--line); overflow-x: auto; padding: 12px; }
    .muted { color: var(--muted); }
    .tag { border: 1px solid var(--line); border-radius: 999px; color: var(--muted); display: inline-block; font-size: 12px; margin: 3px 4px 3px 0; padding: 2px 8px; }
    .meta { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-top: 16px; }
    .metric, .finding, .figure { border: 1px solid var(--line); border-radius: 8px; padding: 13px; }
    .metric span { color: var(--muted); display: block; font-size: 12px; }
    .metric strong { display: block; font-size: 16px; margin-top: 4px; }
    .brief { background: var(--surface); border-left: 4px solid var(--teal); border-radius: 6px; padding: 14px 16px; }
    .grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(285px, 1fr)); }
    .visual-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); }
    .visual-grid .figure:first-child { border-color: rgba(15, 118, 110, 0.38); box-shadow: 0 12px 30px rgba(23, 32, 38, 0.08); }
    .evidence { color: var(--muted); font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 12px; overflow-wrap: anywhere; }
    .signature { color: var(--teal); font-size: 12px; font-weight: 800; letter-spacing: 0.05em; margin-top: 10px; text-transform: uppercase; }
    .badge { border-radius: 999px; color: #fff; display: inline-block; font-size: 12px; padding: 2px 8px; }
    .success, .success_after_retry { background: var(--teal); }
    .failed { background: var(--rose); }
    .skipped, .skipped_optional, .retrying { background: var(--amber); }
    footer { border-top: 1px solid var(--line); color: var(--muted); font-size: 13px; margin-top: 34px; padding-top: 16px; }
  </style>
</head>
<body>
<main>
  <header>
    <h1>SpatialScope Agent Research Brief</h1>
    <p class="muted">{{ research_brief.normalized_question or query }}</p>
    <div>
      <span class="tag">Evidence-linked findings</span>
      <span class="tag">LangGraph trace</span>
      <span class="tag">Chinese-first workspace</span>
      <span class="tag">{{ "LLM enabled" if llm_enabled else "fallback labeled" }}</span>
    </div>
    <div class="signature">{{ project_signature }}</div>
    <div class="meta">
      <div class="metric"><span>Run ID</span><strong>{{ run_id }}</strong></div>
      <div class="metric"><span>Mode</span><strong>{{ mode }}</strong></div>
      <div class="metric"><span>Plan source</span><strong>{{ plan_source }}</strong></div>
      <div class="metric"><span>Evidence packs</span><strong>{{ evidence_packs|length }}</strong></div>
    </div>
  </header>

  {% if primary_figures %}
  <h2>Visual Evidence</h2>
  <p class="muted">Primary spatial evidence is shown first: tissue coordinates, UMAP structure, and requested gene expression panels.</p>
  <div class="visual-grid">
  {% for fig in primary_figures %}
    <section class="figure">
      <h3>{{ fig.title }}</h3>
      <img src="{{ fig.relpath }}" alt="{{ fig.title }}">
      <p>{{ fig.caption }}</p>
      {% if fig.evidence_id %}<p class="evidence">{{ fig.evidence_id }}</p>{% endif %}
      {% if fig.svg_relpath %}<p class="muted"><a href="{{ fig.svg_relpath }}">Editable SVG</a></p>{% endif %}
    </section>
  {% endfor %}
  </div>
  {% endif %}

  <h2>Key Findings</h2>
  {% if findings %}
    <div class="grid">
    {% for finding in findings[:5] %}
      <section class="finding">
        <h3>{{ finding.title }}</h3>
        <p>{{ finding.statement }}</p>
        {% if finding.quantitative_support %}
          <p><strong>Quantitative support:</strong> {{ finding.quantitative_support[:3]|join("; ") }}</p>
        {% endif %}
        <p class="evidence">Evidence: {{ finding.evidence_ids|join(", ") }}</p>
        {% if finding.caveats %}
          <p><strong>Caveat:</strong> {{ finding.caveats[:2]|join(" ") }}</p>
        {% endif %}
      </section>
    {% endfor %}
    </div>
  {% else %}
    <p class="muted">No evidence-linked findings were generated.</p>
  {% endif %}

  <h2>Agent Summary</h2>
  <div class="brief">{{ final_answer }}</div>

  <h2>Dataset Overview</h2>
  <div class="meta">
    <div class="metric"><span>Observations</span><strong>{{ dataset_summary.n_obs or "NA" }}</strong></div>
    <div class="metric"><span>Genes</span><strong>{{ dataset_summary.n_vars or "NA" }}</strong></div>
    <div class="metric"><span>Spatial</span><strong>{{ "yes" if dataset_summary.has_spatial else "no" }}</strong></div>
    <div class="metric"><span>Matrix state</span><strong>{{ dataset_summary.matrix_state or "unknown" }}</strong></div>
  </div>

  <h2>Evidence Packs</h2>
  <table>
    <thead><tr><th>Evidence ID</th><th>Kind</th><th>Tool</th><th>Title</th><th>Layer</th><th>Caveats</th></tr></thead>
    <tbody>
    {% for item in evidence_packs[:32] %}
      <tr>
        <td class="evidence">{{ item.evidence_id }}</td>
        <td>{{ item.kind }}</td>
        <td><code>{{ item.tool }}</code></td>
        <td>{{ item.title }}</td>
        <td>{{ item.data_layer }}</td>
        <td>{{ item.caveats[:2]|join("; ") }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>Supporting Figures</h2>
  {% if supporting_figures %}
  <div class="grid">
  {% for fig in supporting_figures %}
    <section class="figure">
      <h3>{{ fig.title }}</h3>
      <img src="{{ fig.relpath }}" alt="{{ fig.title }}">
      <p>{{ fig.caption }}</p>
      {% if fig.evidence_id %}<p class="evidence">{{ fig.evidence_id }}</p>{% endif %}
      {% if fig.svg_relpath %}<p class="muted"><a href="{{ fig.svg_relpath }}">Editable SVG</a></p>{% endif %}
    </section>
  {% endfor %}
  </div>
  {% else %}
    <p class="muted">No additional supporting figures.</p>
  {% endif %}

  <h2>Tables</h2>
  <ul>
  {% for table in tables %}
    <li><a href="{{ table.relpath }}">{{ table.title }}</a>{% if table.evidence_id %} <span class="evidence">{{ table.evidence_id }}</span>{% endif %}</li>
  {% endfor %}
  </ul>

  <h2>Analysis Plan</h2>
  <p class="muted">{{ plan_rationale }}</p>
  <ol>
  {% for step in plan %}
    <li><code>{{ step.tool }}</code> - {{ step.rationale or step.scientific_purpose }}</li>
  {% endfor %}
  </ol>

  <h2>Execution Trace</h2>
  <table>
    <thead><tr><th>Node</th><th>Tool</th><th>Status</th><th>Duration</th><th>Summary</th></tr></thead>
    <tbody>
    {% for item in trace %}
      <tr>
        <td>{{ item.node }}</td>
        <td><code>{{ item.tool }}</code></td>
        <td><span class="badge {{ item.status }}">{{ item.status }}</span></td>
        <td>{{ item.duration_sec }}</td>
        <td>{{ item.summary }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  {% if clarifications %}
  <h2>Clarification & Repair</h2>
  <table>
    <thead><tr><th>Kind</th><th>Tool</th><th>Message</th><th>Status</th></tr></thead>
    <tbody>
    {% for item in clarifications %}
      <tr><td>{{ item.kind }}</td><td><code>{{ item.tool }}</code></td><td>{{ item.message }}</td><td>{{ item.status }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if repairs %}
  <h2>Repair Diagnostics</h2>
  <table>
    <thead><tr><th>Tool</th><th>Category</th><th>Action</th><th>Likely cause</th></tr></thead>
    <tbody>
    {% for item in repairs %}
      <tr>
        <td><code>{{ item.tool }}</code></td>
        <td>{{ item.category }}</td>
        <td>{{ item.action }}</td>
        <td>{{ item.likely_cause }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {% if warnings or errors %}
  <h2>Warnings / Errors</h2>
  {% if warnings %}<ul>{% for warning in warnings %}<li>{{ warning }}</li>{% endfor %}</ul>{% endif %}
  {% if errors %}<ul>{% for error in errors %}<li>{{ error }}</li>{% endfor %}</ul>{% endif %}
  {% endif %}

  <h2>Acknowledgements</h2>
  <ul>
  {% for item in acknowledgements %}
    <li>{{ item }}</li>
  {% endfor %}
  </ul>

  <footer>{{ project_signature }} · SpatialScope Agent · reproducible spatial transcriptomics research workspace.</footer>
</main>
</body>
</html>
