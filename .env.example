SPATIALSCOPE_LLM_API_KEY=your_llm_api_key_here
SPATIALSCOPE_LLM_BASE_URL=your_openai_compatible_base_url_here
SPATIALSCOPE_LLM_MODEL=glm-5.1
SPATIALSCOPE_LLM_TIMEOUT_SECONDS=10
SPATIALSCOPE_COPILOT_TIMEOUT_SECONDS=45
# auto: configured provider -> full LLM path; missing provider -> deterministic fallback.
# full: require/configure LLM path; fallback: rule-based only.
SPATIALSCOPE_LLM_MODE=auto
SPATIALSCOPE_RANDOM_SEED=0
SPATIALSCOPE_AUTHOR_NAME=
SPATIALSCOPE_AUTHOR_EMAIL=
SPATIALSCOPE_AFFILIATION=Southeast University · Computational Biology
